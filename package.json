{
  "name": "financeguard-starter",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:worker": "npm --workspace apps/api run dev:worker",
    "dev:web": "npm --workspace apps/web-admin run dev",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web-admin run build",
    "typecheck:web": "npm --workspace apps/web-admin run typecheck",
    "test:api": "npm --workspace apps/api run test",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "backup:api": "npm --workspace apps/api run backup",
    "verify:release": "npm run build:api && npm run test:api && npm run typecheck:web && npm run build:web",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d"
  }
}
