HTTP_PORT=80

POSTGRES_DB=financeguard
POSTGRES_USER=financeguard
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# ── Security ────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
PUBLIC_API_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
NEXT_PUBLIC_API_URL=/api

# ── Backup encryption ────────────────────────────────────────────────────────
# Optional: set a 64-char hex key (32 bytes) to use a fixed encryption key for backups.
# If not set, JWT_SECRET is used via HKDF derivation (recommended).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=

# ── Scheduler & background jobs ──────────────────────────────────────────────
SCHEDULER_INTERVAL_MS=3600000
BACKUP_INTERVAL_MS=21600000
NOTIFICATION_DISPATCH_INTERVAL_MS=30000
# How long (ms) a device command can stay PENDING/SENT before being marked FAILED
COMMAND_TIMEOUT_MS=7200000

# ── HTTP tuning ──────────────────────────────────────────────────────────────
BODY_SIZE_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=15

# ── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error  (defaults to info in production)
LOG_LEVEL=info

# ── SMS (webhook-based) ──────────────────────────────────────────────────────
# Point this at any SMS provider that accepts a POST with { to, message, senderId }.
# Compatible with Twilio Messaging Service, Telenor BulkSMS, Zong Business, etc.
SMS_WEBHOOK_URL=https://your-sms-provider.com/send
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=FinanceGuard

# ── Email (webhook-based) ────────────────────────────────────────────────────
# Point this at SendGrid, Mailgun, SES, or any service accepting POST { to, subject, message, from }.
EMAIL_WEBHOOK_URL=https://api.sendgrid.com/v3/mail/send
EMAIL_API_KEY=your-sendgrid-api-key
EMAIL_SENDER=alerts@your-domain.com

# ── WhatsApp (webhook-based) ─────────────────────────────────────────────────
# Point this at Meta Cloud API, Twilio WhatsApp, or any provider accepting POST { to, message, senderId }.
WHATSAPP_WEBHOOK_URL=https://your-whatsapp-provider.com/send
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_SENDER_ID=FinanceGuard

# ── Firebase Cloud Messaging ─────────────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-firebase-private-key\n-----END PRIVATE KEY-----\n"
